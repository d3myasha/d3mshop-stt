# STEALTHNET 3.0 — Telegram Bot
# Достаточно ОДНОГО токена основного бота (как в BotFather). Клоны в .env НЕ добавляются.
BOT_TOKEN=your_telegram_bot_token_from_botfather
API_URL=https://test.stealthnet.app

# Клоны создаются только в админке «Боты-клоны» (таблица bots). При старте контейнер `bot`
# сам запрашивает список активных ботов у API и поднимает long polling на каждый токен.
# После добавления/смены клона: docker compose restart bot
